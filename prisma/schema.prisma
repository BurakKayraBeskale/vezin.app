generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Role: "ADMIN" | "MANAGER" | "EMPLOYEE"
// Status: "TODO" | "IN_PROGRESS" | "REVIEW" | "DONE"
// Priority: "LOW" | "MEDIUM" | "HIGH"
// Department: "OUTSOURCE" | "BAGIMSIZ_DENETIM" | "MUHASEBE" | "YEMINLI_MALI_MUSAVIR" | "ADMIN"

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  password           String
  role               String   @default("EMPLOYEE")
  department         String   @default("OUTSOURCE")
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  assignedTasks      Task[]           @relation("AssignedTo")
  createdTasks       Task[]           @relation("CreatedBy")
  taskAssignees      TaskAssignee[]
  feedbacks          Feedback[]
  files              File[]
  taskLogs           TaskLog[]
  petitions          Petition[]
  leaveRequests      LeaveRequest[]   @relation("LeaveRequests")
  leaveBalances      LeaveBalance[]   @relation("LeaveBalances")
  manages            UserRelation[]   @relation("manages")
  subordinateTo      UserRelation[]   @relation("subordinateTo")
  notifications      Notification[]
  meetingsCreated    Meeting[]        @relation("MeetingCreator")
  meetingAttendees   MeetingAttendee[]
  templates          TaskTemplate[]   @relation("TemplateCreator")
  taskComments       TaskComment[]
  loginLogs          LoginLog[]
  companyAssignments CompanyAssignment[]
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String   // TASK_ASSIGNED | LEAVE_APPROVED | LEAVE_REJECTED | FEEDBACK_RECEIVED | MENTIONED | COMMENTED | COMPANY_5_YEARS
  message   String
  isRead    Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())
}

// relationType: "SUPERIOR" | "PEER" | "SUBORDINATE"
model UserRelation {
  id            String   @id @default(cuid())
  managerId     String
  subordinateId String
  relationType  String   @default("SUBORDINATE")
  manager       User     @relation("manages", fields: [managerId], references: [id], onDelete: Cascade)
  subordinate   User     @relation("subordinateTo", fields: [subordinateId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  @@unique([managerId, subordinateId])
}

// recurringType: "DAILY" | "WEEKLY" | "MONTHLY" | "YEARLY"
// recurringDay: 1-31 for MONTHLY, 0-6 for WEEKLY (0=Mon)
model Task {
  id             String    @id @default(cuid())
  title          String
  description    String?
  status         String    @default("TODO")
  priority       String    @default("MEDIUM")
  assignedTo     User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId   String?
  dueDate        DateTime?
  createdBy      User      @relation("CreatedBy", fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isRecurring    Boolean   @default(false)
  recurringType  String?
  recurringDay   Int?
  nextOccurrence DateTime?
  assignees      TaskAssignee[]
  feedbacks      Feedback[]
  files          File[]
  logs           TaskLog[]
  comments       TaskComment[]
}

model TaskAssignee {
  id     String @id @default(cuid())
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([taskId, userId])
}

model TaskTemplate {
  id            String   @id @default(cuid())
  title         String
  description   String?
  priority      String   @default("MEDIUM")
  estimatedDays Int?
  department    String?
  createdBy     User     @relation("TemplateCreator", fields: [createdById], references: [id])
  createdById   String
  createdAt     DateTime @default(now())
}

model TaskComment {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  content   String
  createdAt DateTime @default(now())
}

model LoginLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model TaskLog {
  id              String    @id @default(cuid())
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId          String
  user            User      @relation(fields: [userId], references: [id])
  userId          String
  action          String    // STARTED | COMPLETED | STATUS_CHANGED | MANUAL_TIME
  fromStatus      String?
  toStatus        String?
  timestamp       DateTime  @default(now())
  durationMinutes Int?
  startedAt       DateTime?
  completedAt     DateTime?
  manualEntry     Boolean   @default(false)
}

model Feedback {
  id         String   @id @default(cuid())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId     String
  fromUser   User     @relation(fields: [fromUserId], references: [id])
  fromUserId String
  message    String
  createdAt  DateTime @default(now())
}

model File {
  id           String   @id @default(cuid())
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId       String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  uploadedById String
  filename     String
  path         String
  comment      String?
  createdAt    DateTime @default(now())
}

// category: "SUGGESTION" | "COMPLAINT" | "PETITION"
model Petition {
  id          String   @id @default(cuid())
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  category    String   // SUGGESTION | COMPLAINT | PETITION
  message     String
  isAnonymous Boolean  @default(false)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// type: "ANNUAL" | "EXCUSE" | "UNPAID"
// status: "PENDING" | "APPROVED" | "REJECTED"
model LeaveRequest {
  id          String    @id @default(cuid())
  user        User      @relation("LeaveRequests", fields: [userId], references: [id])
  userId      String
  startDate   DateTime
  endDate     DateTime
  days        Int
  type        String    // ANNUAL | EXCUSE | UNPAID
  note        String?
  status      String    @default("PENDING")
  reviewedBy  String?
  createdAt   DateTime  @default(now())
}

model LeaveBalance {
  id            String @id @default(cuid())
  user          User   @relation("LeaveBalances", fields: [userId], references: [id])
  userId        String
  year          Int
  totalDays     Int    @default(14)
  usedDays      Int    @default(0)
  remainingDays Int    @default(14)

  @@unique([userId, year])
}

// date: "YYYY-MM-DD" | time: "HH:MM" | duration in minutes
// department: hangi departman davet edildi
model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String   // YYYY-MM-DD
  time        String   // HH:MM
  duration    Int      // 30 | 60 | 120
  department  String
  createdBy   User     @relation("MeetingCreator", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())
  attendees   MeetingAttendee[]
}

// status: "PENDING" | "ACCEPTED" | "DECLINED"
model MeetingAttendee {
  id        String  @id @default(cuid())
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  status    String  @default("PENDING")

  @@unique([meetingId, userId])
}

model Company {
  id          String    @id @default(cuid())
  name        String
  taxNumber   String?
  sector      String?
  startDate   DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  assignments CompanyAssignment[]
}

model CompanyAssignment {
  id         String   @id @default(cuid())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  assignedAt DateTime @default(now())
  assignedBy String   // userId of assigner

  @@unique([companyId, userId])
}
